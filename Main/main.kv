                text: "Burglary"
                background_normal: ""
                background_color: 1, 1, 1, 1
                color: 0, 0, 0, 1
                on_press: app.root.screen_change("location"); app.root.confim_crime(self)

            Button:
                text: "Theft"
                background_normal: ""
